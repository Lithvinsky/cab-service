NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/cab-booking
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Corporate signup: email must end with this domain (lowercase)
CORPORATE_EMAIL_DOMAIN=company.com

CLIENT_ORIGIN=http://localhost:5173

# Employee cancellation: must be at least this many hours before start of booking day (simple rule)
CANCEL_CUTOFF_HOURS_BEFORE_DAY=2
