# Dev: leave unset to use same-origin /api (Vite proxies to backend).
# VITE_API_URL=/api

# Where Vite should forward /api (CabConnect backend in ../backend).
# VITE_PROXY_TARGET=http://127.0.0.1:5000

# Production build: full API base URL including /api suffix.
# VITE_API_URL=https://your-api.example.com/api
